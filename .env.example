# ======================
# Mail: QQ SMTP
# ======================
QQ_MAIL_USER=776257632@qq.com
QQ_MAIL_AUTH=your_qq_mail_auth_code
QQ_MAIL_TO=your_receiver@qq.com

# ======================
# Traffic thresholds
# ======================
TRAFFIC_WARN_MB=500
TRAFFIC_CRITICAL_MB=700
TRAFFIC_SHUTDOWN_MB=900
AUTO_SHUTDOWN=false

# 同类告警冷却秒数，默认 30 分钟
ALERT_COOLDOWN_SECONDS=1800

# 每日最多发信数量
DAILY_MAIL_LIMIT=20

# 检测网站，多个 URL 用英文逗号分隔
CHECK_URLS=https://ethen.qzz.io,https://bt.ethen.qzz.io/ethen

# TCP 端口检查，格式 host:port，多个用逗号分隔
CHECK_TCP=127.0.0.1:42614

# Web 面板配置
WEB_HOST=127.0.0.1
WEB_PORT=8765
WEB_PASSWORD=change-me

# 数据库和日志
DATA_DIR=./data
LOG_DIR=./logs
